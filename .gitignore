# ─────────────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────────────
.env
*.pem
*.key

# ─────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/

# ─────────────────────────────────────────────────
# Virtual environment
# ─────────────────────────────────────────────────
venv/
env/
.venv/

# ─────────────────────────────────────────────────
# Runtime data — generated by the agent, not source
# ─────────────────────────────────────────────────
logs/
data/
*.log

# ─────────────────────────────────────────────────
# OS / editor junk
# ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ─────────────────────────────────────────────────
# Watchdog / misc
# ─────────────────────────────────────────────────
*.pid
nohup.out
