# ─────────────────────────────────────────────────
# .env.example — Copy to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────────

# Groww API — TOTP Flow
GROWW_TOTP_TOKEN=your_totp_token_here
GROWW_TOTP_SECRET=your_totp_secret_here

# Capital in ₹
CAPITAL=50000

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
